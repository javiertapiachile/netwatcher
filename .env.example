# NetWatch v3.0 — Configuración

# Servidor
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Base de datos
DB_PATH=./data/netwatch.db
BLOCKLIST_DIR=./data/blocklists

# TLS
CERT_DIR=./certs

# DNS
DNS_CACHE_TTL=300

# Autenticación — CAMBIAR EN PRODUCCIÓN
JWT_SECRET=genera-un-secreto-largo-y-aleatorio-aqui
JWT_EXPIRES=8h

# Usuario maestro inicial (solo primera ejecución)
# Si no se define, se genera automáticamente y se muestra en consola
MASTER_USER=admin
MASTER_PASS=

# Acceso desde red local
# 0.0.0.0 = accesible desde toda la red local
# 127.0.0.1 = solo localhost
HOST=0.0.0.0

# Redirigir HTTP→HTTPS en puerto 80 (requiere privilegios de admin)
HTTP_REDIRECT=false

# Fase 3 futuro:
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASS=
# ALERT_EMAIL_TO=
