# NetWatch Configuration
# Copy this file to .env and adjust values

PORT=3000
HOST=127.0.0.1
NODE_ENV=development

# Database path (inside container maps to volume)
DB_PATH=./data/netwatch.db

# Refresh interval in seconds (for auto-refresh)
DEFAULT_REFRESH_INTERVAL=5

# DNS cache TTL in seconds
DNS_CACHE_TTL=300

# Future: API keys go here (never hardcode them)
# ABUSEIPDB_API_KEY=
# IPINFO_TOKEN=
